-- Teleport function
local function teleportTo(targetPlayer, executor)
    local character = player.Character
    local targetChar = targetPlayer.Character
    if character and targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.CFrame = targetChar.HumanoidRootPart.CFrame
            addLog(executor.Name .. " [" .. getPlayerRank(executor) .. "] teleported to " .. targetPlayer.Name .. " [" .. getPlayerRank(targetPlayer) .. "]")
        end
    end
end

-- Find player function
local function findPlayer(searchName)
    local searchLower = searchName:lower()
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr.Name:lower():sub(1, #searchLower) == searchLower then
            return plr
        end
        if plr.DisplayName and plr.DisplayName:lower():sub(1, #searchLower) == searchLower then
            return plr
        end
    end
    return nil
end

