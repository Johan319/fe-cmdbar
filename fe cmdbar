-- Command handler
player.Chatted:Connect(function(msg)
    if msg:sub(1, 1) == prefix then
        local args = {}
        for arg in msg:sub(2):gmatch("%S+") do
            table.insert(args, arg)
        end
        
        local command = args[1] and args[1]:lower()
        local targetName = args[2]
        
        -- TP Commands (Moderator+)
        if command == "tp" or command == "goto" or command == "to" then
            if not hasPermission(player, "Moderator") then
                addLog("Permission denied: " .. player.Name .. " tried to use " .. command .. " (Required: Moderator)")
                return
            end
            if targetName then
                local target = findPlayer(targetName)
                if target then
                    teleportTo(target, player)
                    commandCount = commandCount + 1
                    counterLabel.Text = tostring(commandCount)
                else
                    addLog("Player not found: " .. targetName)
                end
            else
                addLog("Usage: " .. prefix .. command .. " <player name>")
            end
        
        -- View / Spectate Commands (Moderator+)
        elseif command == "view" or command == "spectate" then
            if not hasPermission(player, "Moderator") then
                addLog("Permission denied: " .. player.Name .. " tried to use " .. command .. " (Required: Moderator)")
                return
            end
            if targetName then
                local target = findPlayer(targetName)
                if target then
                    if target == player then
                        addLog("You cannot spectate yourself!")
                    else
                        viewPlayer(target)
                        commandCount = commandCount + 1
                        counterLabel.Text = tostring(commandCount)
                    end
                else
                    addLog("Player not found: " .. targetName)
                end
            else
                addLog("Usage: " .. prefix .. command .. " <player name>")
            end
        
        -- Anti-Void Command (Admin+)
        elseif command == "antivoid" then
            if not hasPermission(player, "Admin") then
                addLog("Permission denied: " .. player.Name .. " tried to use antivoid (Required: Admin)")
                return
            end
            loadAntiVoid()
            commandCount = commandCount + 1
            counterLabel.Text = tostring(commandCount)
        
        -- Infinite Jump Command (Moderator+)
        elseif command == "infjump" then
            if not hasPermission(player, "Moderator") then
                addLog("Permission denied: " .. player.Name .. " tried to use infjump (Required: Moderator)")
                return
            end
            loadInfiniteJump()
            commandCount = commandCount + 1
            counterLabel.Text = tostring(commandCount)
        
        -- Prefix Command (Moderator+)
        elseif command == "prefix" then
            if not hasPermission(player, "Moderator") then
                addLog("Permission denied: " .. player.Name .. " tried to use prefix command (Required: Moderator)")
                return
            end
            local newPrefix = args[2]
            if newPrefix and #newPrefix == 1 then
                prefix = newPrefix
                updatePrefixDisplay()
                addLog(player.Name .. " [" .. getPlayerRank(player) .. "] changed prefix to: " .. prefix)
            else
                addLog("Usage: " .. prefix .. "prefix <single character>")
            end
        
        -- Rejoin Command (Member)
        elseif command == "rejoin" then
            game:GetService("TeleportService"):Teleport(game.PlaceId)
        
        -- Reset Command (Member)
        elseif command == "reset" then
            if player.Character then
                player.Character:BreakJoints()
                addLog(player.Name .. " [" .. getPlayerRank(player) .. "] reset their character")
            end
        
        -- Commands List (Member+ - anyone can see commands)
        elseif command == "cmds" or command == "commands" then
            showCommandsPanel()
            addLog(player.Name .. " [" .. getPlayerRank(player) .. "] viewed the commands list")
        end
    end
end)

