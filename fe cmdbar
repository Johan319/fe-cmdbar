-- Function to get a player's rank from the table
local function getPlayerRank(plr)
    local username = plr.Name
    local displayName = plr.DisplayName
    
    if groupRanks[username] then
        return groupRanks[username]
    end
    for name, rank in pairs(groupRanks) do
        if displayName:lower() == name:lower() then
            return rank
        end
    end
    return "Member"
end

-- Function to check if a player has permission (requiredLevel or higher)
local function hasPermission(plr, requiredRank)
    local playerRank = getPlayerRank(plr)
    local playerLevel = rankLevels[playerRank] or 0
    local requiredLevel = rankLevels[requiredRank] or 0
    return playerLevel >= requiredLevel
end

